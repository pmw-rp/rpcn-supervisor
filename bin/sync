#!/bin/sh
# Sync s6 service dirs to match the set of *.yaml files in pipelines/.
# - New config  → create service dirs in pipelines-run/ and internal-run/
# - Removed config → bring services down and remove their dirs
# Safe to run at any time; also runs automatically every 5s via the sync-watcher service.

set -e
BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PIPELINES_DIR="$BASE_DIR/pipelines"
PIPELINES_RUN_DIR="$BASE_DIR/internal/pipelines-run"
INTERNAL_RUN_DIR="$BASE_DIR/internal/internal-run"

mkdir -p "$PIPELINES_RUN_DIR" "$INTERNAL_RUN_DIR"

# --- Add services for new configs ---
for config in "$PIPELINES_DIR"/*.yaml; do
    [ -e "$config" ] || continue
    name="$(basename "$config" .yaml)"
    if [ ! -d "$PIPELINES_RUN_DIR/$name" ]; then
        echo "[sync] Creating service: $name"
        "$BASE_DIR/bin/internal/make-service" "$name" "$config"
    fi
done

# --- Remove services for deleted configs ---
for svc in "$PIPELINES_RUN_DIR"/*/; do
    [ -d "$svc" ] || continue
    name="$(basename "$svc")"
    if [ ! -f "$PIPELINES_DIR/$name.yaml" ]; then
        echo "[sync] Removing service: $name"
        health_svc="$INTERNAL_RUN_DIR/${name}-health"
        if [ -d "$health_svc" ]; then
            s6-svc -wD -T 5000 -d "$health_svc" 2>/dev/null || true
            rm -rf "$health_svc"
        fi
        s6-svc -wD -T 5000 -d "$svc" 2>/dev/null || true
        rm -rf "$svc"
        echo "[sync] Removed: $name"
    fi
done

# Signal the sub-svscans to rescan their directories immediately,
# picking up any newly created or removed service dirs without waiting
# for the default 5s polling interval.
s6-svscanctl -a "$PIPELINES_RUN_DIR" 2>/dev/null || true
s6-svscanctl -a "$INTERNAL_RUN_DIR" 2>/dev/null || true

echo "[sync] Done."
