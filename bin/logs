#!/bin/sh
# Tail logs for one or all pipelines, with human-readable timestamps.
# Usage: bin/logs [<name>]

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
S6TAI="$(command -v s6-tai64nlocal 2>/dev/null)"

decode() {
    if [ -n "$S6TAI" ]; then
        "$S6TAI"
    else
        cat
    fi
}

if [ -n "$1" ]; then
    log="$BASE_DIR/internal/logs/pipelines/$1/current"
    if [ ! -f "$log" ]; then
        echo "No log found for '$1' (expected: $log)" >&2
        exit 1
    fi
    tail -f "$log" | decode
else
    if [ ! -d "$BASE_DIR/internal/logs/pipelines" ] || [ -z "$(ls -A "$BASE_DIR/internal/logs/pipelines" 2>/dev/null)" ]; then
        echo "No logs found. Have any pipelines run yet?" >&2
        exit 1
    fi
    for log in "$BASE_DIR/internal/logs/pipelines"/*/current; do
        [ -f "$log" ] || continue
        name="$(basename "$(dirname "$log")")"
        tail -f "$log" | decode | awk -v name="$name" '{ print name ": " $0; fflush() }' &
    done
    trap 'kill 0' INT TERM
    wait
fi
