#!/bin/sh
# Stop all pipelines cleanly, then stop s6-svscan.

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SERVICES_DIR="$BASE_DIR/services"
PID_FILE="$SERVICES_DIR/.svscan.pid"

# Check svscan is actually running before attempting anything
if ! s6-svscanctl -n "$SERVICES_DIR" 2>/dev/null; then
    echo "[stop-all] s6-svscan is not running." >&2
    rm -f "$PID_FILE"
    exit 1
fi

# Stop each supervised pipeline first so they shut down cleanly
for svc in "$SERVICES_DIR"/*/; do
    [ -d "$svc" ] || continue
    name="$(basename "$svc")"
    echo "[$name] Stopping..."
    s6-svc -wD -T 5000 -d "$svc" 2>/dev/null || true
done

# Tell svscan to exit via its control pipe and wait for it to fully exit
echo "[stop-all] Stopping s6-svscan..."
s6-svscanctl -t "$SERVICES_DIR"

# Wait up to 10s for svscan to exit (it waits for s6-supervise children to die)
i=0
while s6-svscanctl -n "$SERVICES_DIR" 2>/dev/null; do
    i=$(( i + 1 ))
    if [ "$i" -ge 10 ]; then
        echo "[stop-all] Warning: s6-svscan did not exit within 10s" >&2
        break
    fi
    sleep 1
done

rm -f "$PID_FILE"
echo "[stop-all] Done."
