#!/bin/sh
# Stop all pipelines cleanly, then stop s6-svscan.

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SERVICES_DIR="$BASE_DIR/internal/services"
PID_FILE="$SERVICES_DIR/.svscan.pid"

# Check svscan is actually running before attempting anything
if ! s6-svscanctl -n "$SERVICES_DIR" 2>/dev/null; then
    echo "[stop-all] s6-svscan is not running." >&2
    rm -f "$PID_FILE"
    exit 1
fi

# Stop all supervised services cleanly before tearing down the supervisor tree.
# Health checks and sync-watcher must be stopped first to avoid log supervisor
# warnings when internal-svscan shuts down mid-write.
INTERNAL_RUN_DIR="$BASE_DIR/internal/internal-run"
for svc in "$INTERNAL_RUN_DIR"/*/; do
    [ -d "$svc" ] || continue
    s6-svc -wD -T 5000 -d "$svc" 2>/dev/null || true
done

PIPELINES_RUN_DIR="$BASE_DIR/internal/pipelines-run"
for svc in "$PIPELINES_RUN_DIR"/*/; do
    [ -d "$svc" ] || continue
    name="$(basename "$svc")"
    echo "[$name] Stopping..."
    s6-svc -wD -T 5000 -d "$svc" 2>/dev/null || true
done

# Stop the root svscan — this cascades to sub-svscans and all internal services
echo "[stop-all] Stopping s6-svscan..."
s6-svscanctl -t "$SERVICES_DIR"

# Wait up to 20s for the cascade: root → sub-svscans → supervised processes
i=0
while s6-svscanctl -n "$SERVICES_DIR" 2>/dev/null; do
    i=$(( i + 1 ))
    if [ "$i" -ge 20 ]; then
        echo "[stop-all] Warning: s6-svscan did not exit within 20s" >&2
        break
    fi
    sleep 1
done

rm -f "$PID_FILE"
echo "[stop-all] Done."
