#!/bin/sh
# Show status of all supervised pipeline services.

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PIPELINES_RUN_DIR="$BASE_DIR/internal/pipelines-run"

if [ ! -d "$PIPELINES_RUN_DIR" ] || [ -z "$(ls -A "$PIPELINES_RUN_DIR" 2>/dev/null)" ]; then
    echo "No pipelines found. Run: bin/start-all"
    exit 0
fi

echo "Pipeline services:"
echo "─────────────────────────────────────────────────────"
printf "%-20s  %-10s  %s\n" "NAME" "STATE" "PID / UPTIME"
echo "─────────────────────────────────────────────────────"

for svc in "$PIPELINES_RUN_DIR"/*/; do
    [ -d "$svc" ] || continue
    name="$(basename "$svc")"
    info="$(s6-svstat "$svc" 2>/dev/null)" || { printf "%-20s  %-10s\n" "$name" "no-svscan"; continue; }

    state="$(echo "$info" | awk '{print $1}')"
    rest="$(echo "$info" | cut -d' ' -f2-)"
    printf "%-20s  %-10s  %s\n" "$name" "$state" "$rest"
done

echo ""
echo "Log dirs: $BASE_DIR/internal/logs/pipelines/<name>/current"
