#!/bin/sh
# Sync services from pipelines/, start s6-svscan in the background, and return.
# PID is written to services/.svscan.pid for stop-all to use.

set -e
BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SERVICES_DIR="$BASE_DIR/services"
PID_FILE="$SERVICES_DIR/.svscan.pid"

# Use s6-svscanctl as the authoritative liveness check — it talks to the
# control pipe that only exists while svscan is actually running.
if s6-svscanctl -n "$SERVICES_DIR" 2>/dev/null; then
    echo "[start-all] s6-svscan is already running." >&2
    exit 1
fi

echo "[start-all] Syncing pipelines → services..."
"$BASE_DIR/bin/sync"

echo "[start-all] Starting s6-svscan..."
s6-svscan "$SERVICES_DIR" &
echo $! > "$PID_FILE"

echo "[start-all] Started (pid $(cat "$PID_FILE")). Stop with: bin/stop-all"
